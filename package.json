{
  "name": "agent-atlas-root",
  "private": true,
  "version": "0.17.0",
  "description": "Typed context graph and traversal toolkit for AI coding agents.",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "atlas:help": "pnpm --filter @agent-atlas/cli build && node packages/cli/dist/index.js --help",
    "format": "prettier --write .",
    "release:package": "node scripts/release-package.mjs",
    "release:cli:preview": "node scripts/release-package.mjs --package packages/cli --tag preview"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "0.21.5",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
