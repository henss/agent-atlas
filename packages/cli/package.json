{
  "name": "@agent-atlas/cli",
  "version": "0.16.0",
  "description": "Command-line interface for Agent Atlas.",
  "type": "module",
  "bin": {
    "atlas": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@agent-atlas/core": "workspace:*",
    "@agent-atlas/markdown": "workspace:*",
    "@agent-atlas/mcp-server": "workspace:*",
    "@agent-atlas/schema": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "atlas": "node dist/index.js"
  }
}
